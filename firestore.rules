rules_version =  2 ;

service cloud.firestore {
  match /databases/{database}/documents {

    match /courses/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /lessons/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /chat/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
